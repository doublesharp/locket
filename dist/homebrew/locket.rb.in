# frozen_string_literal: true

# Generated by scripts/render-homebrew-formula.sh from a signed release
# source tarball. Do not publish this template directly.
class Locket < Formula
  desc "Local-first secrets control plane for development environments"
  homepage "https://github.com/doublesharp/locket"
  version "__LOCKET_VERSION__"
  url "__LOCKET_SOURCE_TARBALL_URL__"
  sha256 "__LOCKET_SOURCE_TARBALL_SHA256__"
  license "MIT"

  depends_on "rust" => :build

  def install
    system "cargo", "install", "--locked", "--path", "crates/locket-cli", "--root", prefix
  end

  test do
    output = shell_output("#{bin}/locket --version").strip
    assert !output.empty?, "expected non-empty --version output"
  end

  def caveats
    <<~CAVEATS
      Locket stores secrets in an encrypted local vault. CI and production
      secrets should use platform-native stores.
    CAVEATS
  end
end
