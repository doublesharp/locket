{
  "name": "locket-vscode",
  "displayName": "Locket",
  "description": "Local-first secrets management for Visual Studio Code, backed by the Locket agent.",
  "version": "0.0.0-dev",
  "private": true,
  "license": "Apache-2.0 OR MIT",
  "publisher": "locket",
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:locket.revealSecret"
  ],
  "contributes": {
    "commands": [
      {
        "command": "locket.revealSecret",
        "title": "Reveal Secret",
        "category": "Locket"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "lint": "eslint src --ext .ts",
    "test": "pnpm run build && node --test out/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8",
    "typescript": "^5"
  }
}
