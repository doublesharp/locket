# Versioned, hand-curated seed corpora for the thin-corpus targets
# (`fuzz/corpus/<target>/`). Generated/minimised inputs from CI continue to
# be tracked as artefacts — only files committed by hand land here.
!/fuzz/corpus/fuzz_audit_row/*.json
!/fuzz/corpus/fuzz_dotenv_import/*.env
!/fuzz/corpus/fuzz_lk_uri/*.txt
!/fuzz/corpus/fuzz_secret_name/*.txt
/.DS_Store
/.idea/
/.vscode/*
!/.vscode/extensions.json

# Locket must never use plaintext env files as source of truth.
.env
.env.*
.locket.local

# Local diagnostic output must be generated explicitly and reviewed before sharing.
*.redacted-debug.tar
*.lcov
/.worktrees

# Multi-agent coordination state — local only, never committed.
/.agents
/.ready

# locket-app desktop shell artifacts
crates/locket-app/ui/node_modules/
crates/locket-app/ui/dist/
crates/locket-app/ui/.vite/
crates/locket-app/src-tauri/target/
crates/locket-app/src-tauri/gen/
/.claude
