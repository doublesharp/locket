# Locket must never use plaintext env files as source of truth.
.env
.env.*
.locket.local

# Local diagnostic output must be generated explicitly and reviewed before sharing.
*.redacted-debug.tar
*.lcov
/.worktrees

# Multi-agent coordination state — local only, never committed.
/.agents
/.ready

